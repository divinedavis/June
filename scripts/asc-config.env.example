# Copy to scripts/asc-config.env (gitignored) and fill in real values.
# All values are findable in App Store Connect → Users and Access → Integrations → App Store Connect API,
# and in the project's App Store Connect record.

# 10-char alphanumeric, shown next to the key name
ASC_KEY_ID=YOURKEYID

# UUID shown at the top of the keys page
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Absolute path to the .p8 file downloaded when you created the key.
# Convention: ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8 (chmod 600).
ASC_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_YOURKEYID.p8"

# 10-char team ID (seedId on your bundle IDs). Check developer.apple.com/account → Membership.
ASC_TEAM_ID=YOURTEAMID

# Numeric App Store Connect app id. Fastest way: GET /v1/apps?filter[bundleId]=<your bundle id>
# and read the "id" field from the first result.
ASC_APP_ID=0000000000

# Your app's bundle identifier
ASC_BUNDLE_ID=com.divinedavis.june

# Xcode scheme + project (defaults if unset)
# ASC_SCHEME=June
# ASC_PROJECT=June.xcodeproj
